# AI Care Companion - 환경변수 설정 예시
# 이 파일을 .env로 복사하여 사용하세요.
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!

# ============== 앱 기본 설정 ==============
APP_NAME=AI Care Companion
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ============== 데이터베이스 설정 ==============
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=aiboocare
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=aiboocare

# ============== Redis 설정 ==============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============== MQTT 설정 ==============
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=aiboocare-backend

# ============== JWT/인증 설정 ==============
# 반드시 변경하세요! (최소 32자 이상의 랜덤 문자열)
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars

# ============== PII 암호화 설정 ==============
# AES-256-GCM용 32바이트 키 (Base64 인코딩)
# 생성 예: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
PII_ENCRYPTION_KEY=

# ============== 로깅 설정 ==============
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============== CORS 설정 ==============
# 콤마로 구분된 허용 Origin 목록
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
